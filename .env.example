# --- Servidor (Express + tsx): chaves SEM prefixo VITE_ ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Opcional (quando usar Claude no navegador: VITE_AI_PROVIDER=claude)
ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-3-5-sonnet-latest

PORT=8787
AI_PROVIDER_DEFAULT=gemini

# Produção com um único processo (`npm run build && npm start`)
NODE_ENV=development

# --- Frontend Vite ---
# Escolha o provedor exibido no browser (rota final no servidor): gemini | claude
VITE_AI_PROVIDER=gemini

# Só quando o SPA está em OUTRO origin que a API (ex.: frontend Vercel, API Railway)
# VITE_PUBLIC_API_URL=https://api.seudominio.com

# Legado migrado para GEMINI_API_KEY no servidor (não usar VITE_GEMINI_API_KEY no novo fluxo).
