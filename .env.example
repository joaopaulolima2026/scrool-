# ============================================================
# OBRIGATÓRIO
# ============================================================
GEMINI_API_KEY=           # Google AI Studio → Get API Key

# ============================================================
# SUPABASE (obrigatório se usar banco de dados)
# ============================================================
VITE_SUPABASE_URL=         # Supabase Dashboard → Settings → API → Project URL
VITE_SUPABASE_ANON_KEY=    # Supabase Dashboard → Settings → API → anon/public key
SUPABASE_SERVICE_ROLE_KEY= # Supabase Dashboard → Settings → API → service_role key (nunca expor no frontend)

# ============================================================
# OPCIONAL
# ============================================================
ANTHROPIC_API_KEY=        # Necessário apenas se VITE_AI_PROVIDER=claude
# CLAUDE_MODEL=claude-sonnet-4-6

PORT=8787
AI_PROVIDER_DEFAULT=gemini   # gemini | claude
NODE_ENV=development

# Frontend Vite
VITE_AI_PROVIDER=gemini      # gemini | claude

# CORS em produção (separar múltiplos por vírgula)
# CORS_ORIGIN=https://meusite.com,https://app.meusite.com

# Só quando SPA está em origin diferente da API
# VITE_PUBLIC_API_URL=https://api.meusite.com
